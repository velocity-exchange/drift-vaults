{
	"license": "Apache-2.0",
	"scripts": {
		"prettify": "prettier --check './ts/sdk/src/**/*.ts' './tests/**.ts'",
		"prettify:fix": "prettier --write './ts/sdk/src/**/*.ts' './tests/**.ts'",
		"lint": "eslint . --ext ts --quiet",
		"lint:fix": "eslint . --ext ts --fix",
		"prepare": "husky install",
		"program:sync-idl": "cp target/idl/velocity_vaults.json ts/sdk/src/idl/velocity_vaults.json && cp target/types/velocity_vaults.ts ts/sdk/src/types/velocity_vaults.ts && prettier --write ts/sdk/src/types/velocity_vaults.ts",
		"program:build": "anchor build --ignore-keys -- --features anchor-test && bun run program:sync-idl",
		"update-pyth": "cp tests/fixtures/pyth.json target/idl/pyth.json",
		"update-velocity": "cp tests/fixtures/velocity.json target/idl/velocity.json",
		"anchor-tests": "bun run program:sync-idl && bun run update-velocity && bun run update-pyth && bun run jest --runInBand --forceExit"
	},
	"devDependencies": {
		"@coral-xyz/anchor": "npm:@anchor-lang/core@1.0.1",
		"@solana/web3.js": "1.73.2",
		"@velocity-exchange/sdk": "0.1.0",
		"@types/bn.js": "5.1.0",
		"@types/jest": "29.5.14",
		"@types/jest-expect-message": "1.1.0",
		"@typescript-eslint/eslint-plugin": "4.28.0",
		"@typescript-eslint/parser": "4.28.0",
		"anchor-bankrun": "0.3.0",
		"eslint": "7.29.0",
		"eslint-config-prettier": "8.3.0",
		"eslint-plugin-prettier": "3.4.0",
		"husky": "8.0.0",
		"jest": "29.7.0",
		"jest-expect-message": "1.1.3",
		"prettier": "2.6.2",
		"rpc-websockets": "7.5.1",
		"solana-bankrun": "0.3.0",
		"spl-token-bankrun": "0.2.6",
		"ts-jest": "29.2.5",
		"ts-node": "7.0.1",
		"typescript": "5.6.2"
	},
	"engines": {
		"node": ">=22.14.0"
	},
	"dependencies": {
		"@metaplex-foundation/js": "0.20.1"
	},
	"resolutions": {
		"@velocity-exchange/sdk": "0.1.0",
		"@coral-xyz/anchor": "npm:@anchor-lang/core@1.0.1"
	},
	"packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
